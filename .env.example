# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local

# --- APA member portal (required for the scraper) -------------------------
# Credentials for https://league.poolplayers.com — used by scripts/scrape-apa.ts
APA_USERNAME=
APA_PASSWORD=

# Public APA team page URL. The team id is parsed out of this.
APA_TEAM_URL=

# --- APA scraper tuning (optional) ----------------------------------------
# How often to re-fetch member career stats (days). Default: 7
APA_MEMBER_TTL_DAYS=

# How often to re-fetch opponent team data (days). Default: 5
APA_OPPONENT_TTL_DAYS=

# Cap past-team backfill. 0 = unlimited (default).
APA_MAX_PAST_SESSIONS=

# Cap opponent past-session backfill. 0 = unlimited (default).
APA_MAX_OPP_PAST_SESSIONS=

# Soft wall-clock budget for a single scrape run, in minutes.
APA_TIME_BUDGET_MIN=

# Set to 1 to show the browser during a scrape (debug).
APA_HEADFUL=

# --- YouTube highlights (optional) ----------------------------------------
# Enables the Clips section + Hero highlight reel.
YOUTUBE_API_KEY=
YOUTUBE_PLAYLIST_ID=

# --- Shopify storefront (optional, public) --------------------------------
# Powers the merch storefront. All three are required together.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=
NEXT_PUBLIC_SHOPIFY_API_VERSION=

# --- Site config ----------------------------------------------------------
# TikTok handle for the Live CTA. Default: aaronbic
NEXT_PUBLIC_TIKTOK_HANDLE=

# Canonical site URL, used by sitemap.xml / robots.txt.
NEXT_PUBLIC_SITE_URL=

# Shared secret for POST /api/revalidate to force a fresh render.
REVALIDATE_SECRET=

# Password gate for research/preview routes.
RESEARCH_PASSWORD=
